{
  "name": "@nahuelcio/opencode-ado",
  "version": "0.4.1",
  "description": "Azure DevOps plugin for OpenCode — PR reviews, profiles, sidebar panel",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "opencode-ado": "./dist/bin/opencode-ado.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "default": "./dist/tui.tsx"
    }
  },
  "oc-plugin": [
    "server",
    "tui"
  ],
  "pi": {
    "extensions": ["./dist/pi-entry.js"]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/prepare-tui-dist.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "sync:local": "npm run build && node dist/bin/opencode-ado.js sync-local",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opentui/core": "^0.2.2",
    "@opentui/solid": "^0.2.2",
    "solid-js": "^1.9.10",
    "zod": "^4.1.8"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.4.3",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@opencode-ai/plugin": "^1.4.3",
    "@types/node": "^22.0.0",
    "typebox": "^1.1.38",
    "typescript": "^5.8.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "opencode",
    "pi-package",
    "azure-devops",
    "pull-request",
    "code-review",
    "plugin",
    "sidebar"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nahuelcio/azure-devops-cli-go.git",
    "directory": "opencode-plugin"
  }
}
